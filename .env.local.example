# Copy to .env.local. For local dev these are the DEFAULT values printed by `supabase start`.
# When you move to a hosted Supabase project, replace all three with that project's values.

# Public Supabase API URL (local default)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Public anon key — printed by `supabase start` as "anon key". The value below is the
# well-known local-dev default used by the Supabase CLI.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Service-role key — printed by `supabase start` as "service_role key". Server-only; NEVER
# expose to the browser. Used for the Deezer import (writes items as a system actor).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJl8Hfhd_2j2qOC5OJ5jWvIrk0wOdo

# Public site URL — used for canonical tags, OG, and sitemap absolute URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
